{
  "name": "code-arena",
  "private": true,
  "version": "0.1.0",
  "description": "Competitive coding contest platform — timed contests, sandboxed judging, live leaderboards, ratings.",
  "packageManager": "pnpm@9.7.0",
  "engines": { "node": ">=20" },
  "scripts": {
    "build": "turbo run build",
    "dev": "turbo run dev --parallel",
    "lint": "turbo run lint",
    "typecheck": "turbo run typecheck",
    "test": "turbo run test",
    "db:generate": "pnpm --filter @arena/api prisma generate",
    "db:migrate": "pnpm --filter @arena/api prisma migrate dev",
    "db:deploy": "pnpm --filter @arena/api prisma migrate deploy",
    "db:seed": "pnpm --filter @arena/api seed",
    "infra:up": "docker compose up -d",
    "infra:down": "docker compose down"
  },
  "devDependencies": {
    "turbo": "^2.0.9",
    "typescript": "^5.5.4"
  }
}
