# ---- API ----
NODE_ENV=development
API_PORT=8080
JWT_SECRET=change-me-in-prod

# ---- Postgres (system of record) ----
DATABASE_URL=postgresql://arena:arena@localhost:5432/arena?schema=public

# ---- Redis (queue + leaderboard sorted sets) ----
REDIS_URL=redis://localhost:6379

# ---- Object storage (MinIO / S3) for test cases ----
S3_ENDPOINT=http://localhost:9000
S3_REGION=us-east-1
S3_BUCKET=arena-testcases
S3_ACCESS_KEY=minioadmin
S3_SECRET_KEY=minioadmin
S3_FORCE_PATH_STYLE=true

# ---- OAuth (FR-1) ----
GITHUB_CLIENT_ID=
GITHUB_CLIENT_SECRET=
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
OAUTH_REDIRECT_BASE=http://localhost:5173/auth/callback

# ---- Web ----
VITE_API_URL=http://localhost:8080
VITE_WS_URL=ws://localhost:8080/ws
