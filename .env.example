# ---- API ----
NODE_ENV=development
API_PORT=8080
JWT_SECRET=change-me-in-prod

# ---- Postgres (system of record) ----
DATABASE_URL=postgresql://arena:arena@localhost:5432/arena?schema=public

# ---- Redis (queue + leaderboard sorted sets) ----
REDIS_URL=redis://localhost:6379

# ---- Object storage (MinIO / S3) for test cases ----
S3_ENDPOINT=http://localhost:9000
S3_REGION=us-east-1
S3_BUCKET=arena-testcases
S3_ACCESS_KEY=minioadmin
S3_SECRET_KEY=minioadmin
S3_FORCE_PATH_STYLE=true

# ---- OAuth (FR-1) ----
GITHUB_CLIENT_ID=
GITHUB_CLIENT_SECRET=
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
OAUTH_REDIRECT_BASE=http://localhost:5173/auth/callback

# ---- AI opponent ("Challenge the AI") — optional, disabled unless both
# AI_API_KEY and AI_OPPONENT_MODEL are set. Defaults target the Anthropic
# Messages API; override AI_API_URL/AI_API_VERSION for a compatible endpoint. ----
AI_API_KEY=
AI_OPPONENT_MODEL=
AI_OPPONENT_NAME=Arena AI
AI_API_URL=https://api.anthropic.com/v1/messages
AI_API_VERSION=2023-06-01
# Optional extra models (JSON array) + model-vs-model exhibition matches.
AI_MODELS=
AI_VS_AI_ENABLED=false
AI_VS_AI_INTERVAL_SEC=900
# OpenRouter: one key unlocks a multi-vendor roster. List models by OpenRouter id.
# e.g. OPENROUTER_MODELS=[{"name":"GPT-5","model":"openai/gpt-5"}]
OPENROUTER_API_KEY=
OPENROUTER_API_URL=https://openrouter.ai/api/v1/chat/completions
OPENROUTER_MODELS=

# ---- Web ----
VITE_API_URL=http://localhost:8080
VITE_WS_URL=ws://localhost:8080/ws
# Public OAuth client IDs for the login buttons (same values as above; blank
# hides the button). The secret stays server-side only.
VITE_GITHUB_CLIENT_ID=
VITE_GOOGLE_CLIENT_ID=
