# Production env for docker-compose.prod.yml.
#   cp .env.prod.example .env.prod   then fill in the values below.
# Never commit the filled-in .env.prod — it holds secrets.

# ── Public edge ───────────────────────────────────────────────────────────────
# Your domain (A record must point at this VPS; ports 80 + 443 open).
DOMAIN=arena.example.com
# Email Let's Encrypt uses for cert expiry notices.
ACME_EMAIL=you@example.com

# ── Secrets (CHANGE ALL OF THESE) ─────────────────────────────────────────────
# Used to sign auth tokens. Generate: openssl rand -hex 32
JWT_SECRET=replace-with-openssl-rand-hex-32
# Postgres password. Generate: openssl rand -hex 16
POSTGRES_PASSWORD=replace-with-a-strong-password
# MinIO / S3 credentials. Generate each: openssl rand -hex 16
S3_ACCESS_KEY=replace-with-access-key
S3_SECRET_KEY=replace-with-secret-key

# ── Defaults (usually fine) ───────────────────────────────────────────────────
POSTGRES_USER=arena
POSTGRES_DB=arena
S3_REGION=us-east-1
S3_BUCKET=arena-testcases
JUDGE_CONCURRENCY=2
# Days of nightly DB backups to keep in ./backups (see the backup service).
BACKUP_RETENTION_DAYS=7

# ── OAuth (optional — leave blank to disable social login) ─────────────────────
# Set the callback URL in each provider to https://$DOMAIN/auth/callback/<provider>
GITHUB_CLIENT_ID=
GITHUB_CLIENT_SECRET=
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# ── Email notifications (optional — leave blank to disable) ────────────────────
# Contest reminders, streak-lapse nudges, and friend-joined alerts. With no key
# set, emails are only logged (never sent), so the app runs fine without this.
# Get a key at https://resend.com and verify your sending domain, then set
# EMAIL_FROM to an address on that domain (e.g. "Code Arena <hello@$DOMAIN>").
RESEND_API_KEY=
EMAIL_FROM=Code Arena <onboarding@resend.dev>

# ── AI opponent ("Challenge the AI") (optional — leave blank to disable) ───────
# A live duel against an LLM that writes real, judged code. Disabled unless BOTH
# AI_API_KEY and AI_OPPONENT_MODEL are set; then GET /matches/ai/config reports
# enabled and the "Challenge the AI" button appears. Defaults target the
# Anthropic Messages API — override AI_API_URL/AI_API_VERSION for another
# Anthropic-compatible endpoint.
AI_API_KEY=
AI_OPPONENT_MODEL=
AI_OPPONENT_NAME=Arena AI
AI_API_URL=https://api.anthropic.com/v1/messages
AI_API_VERSION=2023-06-01
# Optional multi-model roster: a JSON array of additional opponents. The single
# vars above are always the first ("house") model; these are appended. Each entry
# is { name, model, apiKey, apiUrl?, apiVersion?, api? } where api is "anthropic"
# (default) or "openai" for OpenAI-shaped endpoints.
# Example: [{"name":"Rival","model":"<wire-id>","apiKey":"<key>"}]
AI_MODELS=
# Model-vs-model exhibition matches that populate the AI-vs-AI board. Off by
# default (they spend model budget); needs >=2 configured models to do anything.
AI_VS_AI_ENABLED=false
AI_VS_AI_INTERVAL_SEC=900

# OpenRouter — the easy path to a multi-vendor roster (GPT, Gemini, DeepSeek,
# Qwen, Llama, …) behind ONE key. Set the key, then list models by their
# OpenRouter id; each becomes an OpenAI-format opponent automatically.
# Get a key at https://openrouter.ai/keys and model ids at https://openrouter.ai/models
OPENROUTER_API_KEY=
OPENROUTER_API_URL=https://openrouter.ai/api/v1/chat/completions
# A popular starter roster (verify each id against https://openrouter.ai/models —
# a wrong/renamed slug just makes that model sit out, it won't error):
# OPENROUTER_MODELS=[{"name":"GPT-5","model":"openai/gpt-5"},{"name":"Gemini 3 Pro","model":"google/gemini-3-pro"},{"name":"DeepSeek R1","model":"deepseek/deepseek-r1"},{"name":"Qwen Coder","model":"qwen/qwen-2.5-coder-32b-instruct"},{"name":"Llama 3.3 70B","model":"meta-llama/llama-3.3-70b-instruct"},{"name":"Grok","model":"x-ai/grok-4"},{"name":"Mistral Large","model":"mistralai/mistral-large"}]
OPENROUTER_MODELS=
