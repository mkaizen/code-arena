# Production env for docker-compose.prod.yml.
#   cp .env.prod.example .env.prod   then fill in the values below.
# Never commit the filled-in .env.prod — it holds secrets.

# ── Public edge ───────────────────────────────────────────────────────────────
# Your domain (A record must point at this VPS; ports 80 + 443 open).
DOMAIN=arena.example.com
# Email Let's Encrypt uses for cert expiry notices.
ACME_EMAIL=you@example.com

# ── Secrets (CHANGE ALL OF THESE) ─────────────────────────────────────────────
# Used to sign auth tokens. Generate: openssl rand -hex 32
JWT_SECRET=replace-with-openssl-rand-hex-32
# Postgres password. Generate: openssl rand -hex 16
POSTGRES_PASSWORD=replace-with-a-strong-password
# MinIO / S3 credentials. Generate each: openssl rand -hex 16
S3_ACCESS_KEY=replace-with-access-key
S3_SECRET_KEY=replace-with-secret-key

# ── Defaults (usually fine) ───────────────────────────────────────────────────
POSTGRES_USER=arena
POSTGRES_DB=arena
S3_REGION=us-east-1
S3_BUCKET=arena-testcases
JUDGE_CONCURRENCY=2
# Days of nightly DB backups to keep in ./backups (see the backup service).
BACKUP_RETENTION_DAYS=7

# ── OAuth (optional — leave blank to disable social login) ─────────────────────
# Set the callback URL in each provider to https://$DOMAIN/auth/callback/<provider>
GITHUB_CLIENT_ID=
GITHUB_CLIENT_SECRET=
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# ── Email notifications (optional — leave blank to disable) ────────────────────
# Contest reminders, streak-lapse nudges, and friend-joined alerts. With no key
# set, emails are only logged (never sent), so the app runs fine without this.
# Get a key at https://resend.com and verify your sending domain, then set
# EMAIL_FROM to an address on that domain (e.g. "Code Arena <hello@$DOMAIN>").
RESEND_API_KEY=
EMAIL_FROM=Code Arena <onboarding@resend.dev>
