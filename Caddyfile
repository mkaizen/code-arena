# Public edge for Code Arena. Caddy auto-provisions a TLS cert for $DOMAIN
# (Let's Encrypt) — point the domain's A record at this host and open 80/443.
{
	email {$ACME_EMAIL}
}

{$DOMAIN} {
	encode gzip zstd

	# API + WebSocket. handle_path strips the /api prefix, so the API (and the
	# /ws upgrade) see root paths. reverse_proxy upgrades WebSockets natively.
	handle_path /api/* {
		reverse_proxy api:8080
	}

	# Dynamic sitemap lives at the site root (crawler convention) but is served
	# by the API so it always reflects the current problem bank.
	handle /sitemap.xml {
		reverse_proxy api:8080
	}

	# SPA + prerendered pages. If a prerendered clean-URL page exists
	# (e.g. /problems/two-sum → /srv/problems/two-sum.html from prerender.mjs),
	# rewrite to it — before try_files, so the enclosing directory can't match
	# and trigger a trailing-slash redirect. Otherwise serve the asset if it
	# exists, else fall back to the SPA shell for client-side routes.
	handle {
		root * /srv
		@prerendered {
			file {path}.html
		}
		rewrite @prerendered {path}.html
		try_files {path} /index.html
		file_server
	}
}
