// Code Arena — relational system of record (FR-1..FR-26 backing store).
generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum Role {
  USER
  SETTER
  ADMIN
}

enum Difficulty {
  easy
  med
  hard
}

enum ScoringModel {
  ICPC
  POINTS
}

enum Verdict {
  ACCEPTED
  WRONG_ANSWER
  TIME_LIMIT_EXCEEDED
  MEMORY_LIMIT_EXCEEDED
  RUNTIME_ERROR
  COMPILATION_ERROR
  INTERNAL_ERROR
  PENDING
  JUDGING
}

enum MatchStatus {
  ACTIVE
  FINISHED
}

enum MatchMode {
  ROYALE // 6-player elimination ladder
  DUEL   // 1v1, best-of-3 rounds, first AC takes the round
}

enum MatchPlayerStatus {
  ALIVE
  ELIMINATED
}

model User {
  id            String   @id @default(cuid())
  handle        String   @unique
  email         String   @unique
  passwordHash  String?  // null when OAuth-only (FR-1)
  role          Role     @default(USER)
  rating        Int      @default(1500)
  defaultLang   String   @default("cpp") // FR-3
  editorPrefs   Json?    // FR-3
  createdAt     DateTime @default(now())
  // Referral growth loop: set once at registration, never changes.
  referredById  String?
  referredBy    User?    @relation("Referrals", fields: [referredById], references: [id])
  referrals     User[]   @relation("Referrals")

  // Daily-challenge streak. Denormalized so profiles/share cards read it in
  // O(1); the DailySolve rows below are the source of truth for the calendar.
  currentStreak Int       @default(0)
  longestStreak Int       @default(0)
  lastDailyDate DateTime? @db.Date // UTC date of the most recently solved daily

  // Email notifications (opt-out by default off = subscribed). notifyToken
  // backs one-click unsubscribe links; lastNudgeDate dedupes streak reminders.
  emailOptOut   Boolean   @default(false)
  notifyToken   String?   @unique
  lastNudgeDate DateTime? @db.Date

  oauthAccounts   OAuthAccount[]
  submissions     Submission[]
  registrations   Registration[]
  ratingChanges   RatingChange[]
  matchPlayers    MatchPlayer[]
  matchQueueEntry MatchQueueEntry?
  dailySolves     DailySolve[]
  ghostRuns       GhostRun[]

  @@index([rating])
  @@index([referredById])
}

model OAuthAccount {
  id         String @id @default(cuid())
  provider   String // "github" | "google"
  providerId String
  user       User   @relation(fields: [userId], references: [id])
  userId     String

  @@unique([provider, providerId])
}

model Problem {
  id          String     @id @default(cuid())
  slug        String     @unique
  title       String
  statement   String     // markdown/HTML
  editorial   String?    // optional solution write-up (HTML); indexable SEO depth
  difficulty  Difficulty
  ratingValue Int        // numeric difficulty (FR-5)
  tags        String[]   // FR-5
  timeMs      Int        // FR-6
  memoryKb    Int        // FR-6
  // Hidden judge data lives in object storage; we keep a pointer (FR-4).
  testsKey    String     // e.g. "problems/<id>/tests.tar"
  testCount   Int        @default(0)
  version     Int        @default(1) // FR-7
  createdAt   DateTime   @default(now())

  samples         Sample[]
  contestProblems ContestProblem[]
  matchProblems   MatchProblem[]
  submissions     Submission[]
  dailyChallenges DailyChallenge[]
  ghostRuns       GhostRun[]
  versions        ProblemVersion[]
}

// FR-7: an immutable snapshot of a problem's editable definition at a given
// version. One row is written for the pre-edit state on every update (and on
// restore), so setters can see the edit history and roll back. Hidden judge
// tests live in object storage and are replaced in place, so only their count
// is snapshotted here — the statement, metadata, and samples are the versioned
// definition.
model ProblemVersion {
  id           String     @id @default(cuid())
  problem      Problem    @relation(fields: [problemId], references: [id])
  problemId    String
  version      Int        // the version number this snapshot represents
  title        String
  statement    String
  editorial    String?
  difficulty   Difficulty
  ratingValue  Int
  tags         String[]
  timeMs       Int
  memoryKb     Int
  samples      Json       // [{ input, output }] captured at this version
  testCount    Int
  editorHandle String?    // who made the edit that superseded this version
  createdAt    DateTime   @default(now()) // when this version was superseded

  @@unique([problemId, version])
  @@index([problemId, createdAt])
}

model Sample {
  id        String  @id @default(cuid())
  problem   Problem @relation(fields: [problemId], references: [id])
  problemId String
  input     String
  output    String
  ordinal   Int
}

model Contest {
  id           String       @id @default(cuid())
  name         String
  startsAt     DateTime     // FR-8 (server clock authoritative — NFR-4)
  durationSec  Int          // FR-8
  scoring      ScoringModel @default(ICPC) // FR-11
  rated        Boolean      @default(true)
  freezeSec    Int          @default(1800) // FR-12: freeze window before end
  createdAt    DateTime     @default(now())

  problems      ContestProblem[]
  registrations Registration[]
  submissions   Submission[]
  ratingChanges RatingChange[]

  @@index([startsAt])
}

model ContestProblem {
  contest   Contest @relation(fields: [contestId], references: [id])
  contestId String
  problem   Problem @relation(fields: [problemId], references: [id])
  problemId String
  label     String  // "A", "B", ...
  points    Int     @default(100) // used by POINTS scoring (FR-11)

  @@id([contestId, problemId])
}

model Registration {
  contest   Contest @relation(fields: [contestId], references: [id])
  contestId String
  user      User    @relation(fields: [userId], references: [id])
  userId    String
  remindAt   DateTime? // FR-26
  remindedAt DateTime? // set once the start-reminder email has gone out
  createdAt  DateTime  @default(now())

  @@id([contestId, userId])
}

model Submission {
  id          String   @id @default(cuid())
  user        User     @relation(fields: [userId], references: [id])
  userId      String
  problem     Problem  @relation(fields: [problemId], references: [id])
  problemId   String
  contest     Contest? @relation(fields: [contestId], references: [id])
  contestId   String?
  match       Match?   @relation(fields: [matchId], references: [id])
  matchId     String?
  language    String
  source      String
  verdict     Verdict  @default(PENDING)
  failedCase  Int?
  timeMs      Int?
  memoryKb    Int?
  // FR-4/FR-25: practice submissions are judged identically but unrated.
  rated       Boolean  @default(false)
  createdAt   DateTime @default(now())
  judgedAt    DateTime?

  @@index([userId, createdAt])
  @@index([contestId, problemId])
  @@index([matchId, problemId])
}

model RatingChange {
  id        String   @id @default(cuid())
  user      User     @relation(fields: [userId], references: [id])
  userId    String
  contest   Contest  @relation(fields: [contestId], references: [id])
  contestId String
  before    Int
  after     Int
  rank      Int
  createdAt DateTime @default(now())

  @@unique([userId, contestId]) // FR-21/FR-22, deterministic & reproducible (NFR-6)
}

// ── Battle Royale mode ───────────────────────────────────────────────────────
// 6 players queue, then race through an ascending-difficulty problem ladder.
// Each round has a hard timer; anyone who hasn't solved it when time's up is
// eliminated. Last player standing wins.

model Match {
  id               String      @id @default(cuid())
  mode             MatchMode   @default(ROYALE)
  status           MatchStatus @default(ACTIVE)
  round            Int         @default(0)
  roundStartedAt   DateTime    @default(now())
  roundDurationSec Int         @default(300)
  createdAt        DateTime    @default(now())
  endedAt          DateTime?

  players     MatchPlayer[]
  problems    MatchProblem[]
  submissions Submission[]

  @@index([status])
}

model MatchProblem {
  match     Match   @relation(fields: [matchId], references: [id])
  matchId   String
  problem   Problem @relation(fields: [problemId], references: [id])
  problemId String
  round     Int

  @@id([matchId, round])
}

model MatchPlayer {
  match           Match             @relation(fields: [matchId], references: [id])
  matchId         String
  user            User              @relation(fields: [userId], references: [id])
  userId          String
  status          MatchPlayerStatus @default(ALIVE)
  eliminatedRound Int?
  placement       Int?
  // DUEL: rounds won so far (first accepted submission takes the round).
  roundWins       Int               @default(0)
  // Left the match — no recent heartbeat past the grace window (FR: forfeit).
  forfeited       Boolean           @default(false)
  lastSeenAt      DateTime?
  // Rating snapshot applied when the match finishes (matches are rated).
  ratingBefore    Int?
  ratingAfter     Int?

  @@id([matchId, userId])
}

model MatchQueueEntry {
  user     User      @relation(fields: [userId], references: [id])
  userId   String    @id
  mode     MatchMode @default(ROYALE)
  queuedAt DateTime  @default(now())
  // Referral perk: Recruiter-badge holders (see rewards.ts) cut the queue,
  // snapshotted at join time so ordering doesn't require a join per poll.
  priority Boolean   @default(false)
}

// One featured problem per UTC calendar day. Rows are created lazily on the
// first request for a given day (see daily.ts) and never change afterward, so
// growing the problem bank can't retroactively alter a past day's challenge.
model DailyChallenge {
  date      DateTime @id @db.Date
  problem   Problem  @relation(fields: [problemId], references: [id])
  problemId String
  createdAt DateTime @default(now())
}

// A user's successful solve of a given day's challenge — the source of truth
// for the streak calendar. The denormalized counters on User are derived from
// these and updated in the same transaction that inserts a row.
model DailySolve {
  user      User     @relation(fields: [userId], references: [id])
  userId    String
  date      DateTime @db.Date
  problemId String
  solvedAt  DateTime @default(now())

  @@id([userId, date])
  @@index([userId])
}

// A recorded solve run for ghost racing: race a replay of someone's past solve.
// totalMs is the wall-clock start→first-AC time, measured server-side from a
// Redis race record (see ghost.ts) so it can't be fabricated. events is a small
// [{offsetMs, verdict}] trail for flavour markers on the race bar.
model GhostRun {
  id        String   @id @default(cuid())
  problem   Problem  @relation(fields: [problemId], references: [id])
  problemId String
  user      User     @relation(fields: [userId], references: [id])
  userId    String
  totalMs   Int
  events    Json
  createdAt DateTime @default(now())

  @@index([problemId, totalMs])
}
